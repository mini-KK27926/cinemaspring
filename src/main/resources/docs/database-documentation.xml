<?xml version="1.0" encoding="UTF-8"?>
<!--
    XML документация к проекту "Система управления кинотеатром"
    Автор: Кискичева Ксения
-->
<project-documentation>
    <database>
        <description>
            База данных кинотеатра содержит 6 взаимосвязанных таблиц.
            Используется PostgreSQL в продакшене и H2 для тестирования.
            Миграции управляются через Liquibase.
        </description>

        <tables>
            <!-- Таблица 1: Фильмы -->
            <table name="film" entity="Film">
                <purpose>Хранение информации о фильмах</purpose>
                <columns>
                    <column name="id" type="Long" constraint="PRIMARY KEY, AUTO_INCREMENT"/>
                    <column name="title" type="String" constraint="NOT NULL" description="Название фильма"/>
                    <column name="duration_minutes" type="Integer" description="Длительность в минутах"/>
                    <column name="genre" type="String" description="Жанр фильма"/>
                    <column name="description" type="String" description="Описание фильма"/>
                    <column name="created_at" type="Timestamp" description="Дата добавления"/>
                </columns>
            </table>

            <!-- Таблица 2: Залы -->
            <table name="hall" entity="Hall">
                <purpose>Хранение информации о кинозалах</purpose>
                <columns>
                    <column name="id" type="Long" constraint="PRIMARY KEY"/>
                    <column name="name" type="String" constraint="NOT NULL" description="Название зала"/>
                    <column name="capacity" type="Integer" constraint="NOT NULL" description="Вместимость"/>
                    <column name="has_3d" type="Boolean" description="Поддержка 3D"/>
                    <column name="description" type="String" description="Описание зала"/>
                </columns>
            </table>

            <!-- Таблица 3: Сеансы -->
            <table name="session" entity="Session">
                <purpose>Расписание сеансов</purpose>
                <columns>
                    <column name="id" type="Long" constraint="PRIMARY KEY"/>
                    <column name="film_id" type="Long" constraint="FOREIGN KEY (film.id)" description="Ссылка на фильм"/>
                    <column name="hall_id" type="Long" constraint="FOREIGN KEY (hall.id)" description="Ссылка на зал"/>
                    <column name="start_time" type="Timestamp" constraint="NOT NULL" description="Время начала"/>
                    <column name="end_time" type="Timestamp" description="Время окончания"/>
                    <column name="price" type="BigDecimal" constraint="NOT NULL" description="Цена билета"/>
                </columns>
            </table>

            <!-- Таблица 4: Билеты -->
            <table name="ticket" entity="Ticket">
                <purpose>Билеты на сеансы</purpose>
                <columns>
                    <column name="id" type="Long" constraint="PRIMARY KEY"/>
                    <column name="session_id" type="Long" constraint="FOREIGN KEY (session.id)" description="Ссылка на сеанс"/>
                    <column name="seat_number" type="Integer" constraint="NOT NULL" description="Номер места"/>
                    <column name="row_number" type="Integer" constraint="NOT NULL" description="Номер ряда"/>
                    <column name="status" type="String" description="Статус: AVAILABLE, BOOKED, SOLD"/>
                </columns>
            </table>

            <!-- Таблица 5: Продажи -->
            <table name="sale" entity="Sale">
                <purpose>Информация о продажах билетов</purpose>
                <columns>
                    <column name="id" type="Long" constraint="PRIMARY KEY"/>
                    <column name="ticket_id" type="Long" constraint="FOREIGN KEY (ticket.id)" description="Ссылка на билет"/>
                    <column name="cashier_id" type="Long" constraint="FOREIGN KEY (cashier.id)" description="Ссылка на кассира"/>
                    <column name="sale_time" type="Timestamp" description="Время продажи"/>
                    <column name="price" type="BigDecimal" description="Фактическая цена продажи"/>
                    <column name="payment_method" type="String" description="Способ оплаты"/>
                </columns>
            </table>

            <!-- Таблица 6: Кассиры -->
            <table name="cashier" entity="Cashier">
                <purpose>Сотрудники-кассиры</purpose>
                <columns>
                    <column name="id" type="Long" constraint="PRIMARY KEY"/>
                    <column name="name" type="String" constraint="NOT NULL" description="ФИО кассира"/>
                    <column name="email" type="String" description="Email для уведомлений"/>
                    <column name="phone" type="String" description="Телефон"/>
                    <column name="hire_date" type="Date" description="Дата найма"/>
                </columns>
            </table>
        </tables>

        <relationships>
            <relationship type="ManyToOne">
                <from table="session" column="film_id"/>
                <to table="film" column="id"/>
                <description>Один фильм может быть показан в多个 сеансах</description>
            </relationship>
            <relationship type="ManyToOne">
                <from table="session" column="hall_id"/>
                <to table="hall" column="id"/>
                <description>В одном зале может проходить多个 сеансов</description>
            </relationship>
            <relationship type="ManyToOne">
                <from table="ticket" column="session_id"/>
                <to table="session" column="id"/>
                <description>На один сеанс продается多个 билетов</description>
            </relationship>
            <relationship type="OneToOne">
                <from table="sale" column="ticket_id"/>
                <to table="ticket" column="id"/>
                <description>Одна продажа соответствует одному билету</description>
            </relationship>
            <relationship type="ManyToOne">
                <from table="sale" column="cashier_id"/>
                <to table="cashier" column="id"/>
                <description>Один кассир может совершить多个 продаж</description>
            </relationship>
        </relationships>
    </database>

    <application-info>
        <name>Cinema Management System</name>
        <version>1.0.0</version>
        <technology-stack>
            <technology>Java 17</technology>
            <technology>Spring Boot 3.x</technology>
            <technology>Spring MVC</technology>
            <technology>Thymeleaf</technology>
            <technology>Spring Data JPA</technology>
            <technology>PostgreSQL / H2</technology>
            <technology>Liquibase</technology>
            <technology>Bootstrap 5</technology>
        </technology-stack>

        <controllers>
            <controller>FilmController - управление фильмами</controller>
            <controller>HallController - управление залами</controller>
            <controller>SessionController - управление сеансами</controller>
            <controller>TicketController - управление билетами</controller>
            <controller>SaleController - управление продажами</controller>
            <controller>CashierController - управление кассирами</controller>
            <controller>MainController - главная страница</controller>
        </controllers>

        <functions-implemented>
            <function>Просмотр всех записей (GET /entity)</function>
            <function>Детальный просмотр (GET /entity/{id})</function>
            <function>Создание записи (GET/POST /entity/new)</function>
            <function>Редактирование записи (GET/POST /entity/{id}/edit)</function>
            <function>Удаление записи (POST /entity/{id}/delete)</function>
        </functions-implemented>
    </application-info>
</project-documentation>